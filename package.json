{
  "name": "@devrev/ts-adaas",
  "version": "1.19.11-beta.0",
  "description": "Typescript library containing the ADaaS(AirDrop as a Service) control protocol.",
  "type": "commonjs",
  "main": "./dist/index.js",
  "typings": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p ./tsconfig.json",
    "prepare": "npm run build",
    "start": "ts-node src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint .  --fix",
    "test": "jest --silent --forceExit --maxWorkers=50% --selectProjects default --",
    "test:backwards-compatibility": "jest --silent --forceExit --selectProjects backwards-compatibility --",
    "test:timeout-handling": "jest --silent --forceExit --selectProjects timeout-handling --",
    "test:slow": "jest --silent --forceExit --selectProjects slow --",
    "test:coverage": "jest --silent --forceExit --coverage --runInBand --",
    "test:debug": "jest --forceExit --selectProjects default --"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devrev/adaas-sdk.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "keywords": [],
  "author": "devrev",
  "license": "ISC",
  "devDependencies": {
    "@microsoft/api-extractor": "^7.57.6",
    "@microsoft/api-extractor-model": "^7.30.7",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.18.0",
    "@types/yargs": "^17.0.33",
    "ajv": "^8.18.0",
    "eslint": "9.32.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "4.0.0",
    "jest": "^29.7.0",
    "jiti": "^2.6.1",
    "prettier": "^2.8.3",
    "ts-jest": "^29.4.4",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.46.1"
  },
  "dependencies": {
    "@devrev/typescript-sdk": "^1.1.78",
    "axios": "^1.17.0",
    "axios-retry": "^4.5.0",
    "form-data": "^4.0.4",
    "js-jsonl": "^1.1.1",
    "ts-node": "^10.9.2",
    "yargs": "^17.7.3"
  },
  "files": [
    "dist/**/*",
    "!dist/tests/**/*"
  ]
}
